# Shared JWT signing secret for auth-service and api-gateway.
# Generate a 32-byte Base64 value for local runs.
JWT_SECRET_BASE64=

# Service-to-service token for /internal/** endpoints.
INTERNAL_API_TOKEN=

# Optional gateway CORS allow-list (comma-separated origin patterns).
GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173

# Optional: enable Redis-backed gateway rate limiting.
GATEWAY_REDIS_RATE_LIMIT_ENABLED=true
